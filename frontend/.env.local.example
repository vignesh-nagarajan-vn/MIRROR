# MIRROR frontend environment.
# Copy to .env.local for local development:  cp .env.local.example .env.local

# Where analyze requests are sent.
#   - Leave UNSET (or empty) to use the built-in same-origin serverless route
#     at /api/analyze. This is the Vercel deployment path (Claude vision).
#   - Set to your local FastAPI backend to run the real PyTorch pipeline:
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Only needed for the serverless (Vercel) analyze route ---
# Server-side only; never prefixed with NEXT_PUBLIC. Set this in the Vercel
# project settings (or here for `vercel dev`) to enable live Claude analysis.
# Without it, the serverless route returns a clearly-labelled demo result.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
